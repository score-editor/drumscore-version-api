# Analytics Secret for Request Signing
# Generate a strong random secret: openssl rand -base64 32
# This secret must match the one embedded in your client application
ANALYTICS_SECRET=your-secret-here-change-this

# Example:
# ANALYTICS_SECRET=drumscore_analytics_2025_AbCdEfGh123456

# Admin Secret for UAT Build & Link Management
# Generate a strong random secret: openssl rand -base64 32
# Used with: Authorization: Bearer <this-value>
# Retrieve from droid1: cat .env
ADMIN_SECRET=your-admin-secret-here-change-this
